# Database PostgreSQL (Global)
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Service Database URLs
AUTH_DATABASE_URL=postgresql://user:password@db:5432/auth_db
TRIAGEM_DATABASE_URL=postgresql+psycopg://user:password@db:5432/triagem_db
CLASSIFICACAO_DATABASE_URL=postgresql+psycopg://user:password@db:5432/classificacao_db
PRONTUARIO_DATABASE_URL=postgresql://user:password@db:5432/prontuario_db

# JWT & Auth
JWT_SECRET=super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Business Rules
CRITICAL_CAPACITY_LIMIT=10
TRIAGE_VALIDITY_HOURS=4

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=medsync_events
RABBITMQ_QUEUE=queue.events

# Logging
LOG_LEVEL=INFO
